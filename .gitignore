# ── Inkling repo .gitignore ───────────────────────────────────────────

# Internal-only planning & strategy
docs/internal/
*.internal.md
/product-plan*
/usecases-*
/three-product-*
/reality-to-game-*

# (pipeline.json is not ignored — the runner needs it at runtime.)
docs/*.pdf
*-Spec.pdf

# Secrets / env
.env
.env.*
*.key
*.pem
openai.key

# Node / build
node_modules/
dist/
build/
*.tsbuildinfo
.DS_Store

# Logs / scratch
*.log
tmp/
scratch/
output/
.playwright-cli/

.claude/
.cursor/
.aider*
.goal

# Local generated drawing/evaluation sets live in the named Downloads folder.
# They are large test inputs, not product source or committed customer data.
fixtures/validation-drawings/
