# ── Inkling repo .gitignore ───────────────────────────────────────────

# Internal-only planning & strategy
docs/internal/
*.internal.md
/product-plan*
/usecases-*
/three-product-*
/reality-to-game-*

# (pipeline.json is not ignored — the runner needs it at runtime.)
docs/*.pdf
*-Spec.pdf

# Secrets / env
.env
.env.*
*.key
*.pem
openai.key

# Node / build
node_modules/
dist/
build/
*.tsbuildinfo
.DS_Store

# Logs / scratch
*.log
tmp/
scratch/
output/
.playwright-cli/

.claude/
.cursor/
.aider*
.goal

# The round-1 validation corpus is tracked: it is generated test drawings the
# verify chain and corpus baselines depend on, not customer data. Scratch
# rounds beyond it stay local.
fixtures/validation-drawings/*
!fixtures/validation-drawings/round-1/
