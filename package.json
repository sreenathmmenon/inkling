{
  "name": "inkling",
  "version": "1.0.0",
  "type": "module",
  "description": "Turns the **Prompt & Model Engineering Spec PDF** into something that runs itself. No more copy-pasting each prompt into the right model by hand.",
  "main": "dist/runner/pipeline.js",
  "types": "dist/runner/pipeline.d.ts",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "verify": "npm run test && npm run audit:strict && python3 runner/extract_from_pdf.py --pdf docs/Inkling-Spec.pdf --spec spec/pipeline.json --verify",
    "audit:strict": "npm run build && node dist/runner/strict-schema-audit.js",
    "dry-run": "npm run build && node dist/runner/dry-run.js",
    "scan": "npm run build && node --env-file=.env dist/scripts/scan.js",
    "solvability": "npm run build && node --test dist/tests/solvability.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sreenathmmenon/inkling.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/sreenathmmenon/inkling/issues"
  },
  "homepage": "https://github.com/sreenathmmenon/inkling#readme",
  "dependencies": {
    "openai": "^6.47.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
