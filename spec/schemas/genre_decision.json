{
  "name": "GenreDecision",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["primary_genre", "alt_genre", "rationale_for_log"],
    "properties": {
      "primary_genre": { "type": "string", "enum": ["platformer","maze","runner","slingshot"] },
      "alt_genre": { "type": "string", "enum": ["platformer","maze","runner","slingshot"] },
      "rationale_for_log": { "type": "string" }
    }
  },
  "strict": true
}
