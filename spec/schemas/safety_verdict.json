{
  "name": "SafetyVerdict",
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": ["verdict", "reason_code"],
    "properties": {
      "verdict": { "type": "string", "enum": ["allow", "block", "uncertain"] },
      "reason_code": {
        "type": ["string", "null"],
        "enum": ["face_detected", "personal_data", "unsafe_content", "injection", "none", null]
      }
    }
  },
  "strict": true
}
